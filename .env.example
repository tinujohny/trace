# Phase 6+ — copy to .env.local (not only .env), then restart: npm run dev
# OpenAI: sk-... keys → api.openai.com (default model gpt-4o-mini)
# Groq:   gsk_... keys → auto-detected; use OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional override (e.g. https://api.groq.com/openai/v1)
# OPENAI_BASE_URL=

# Force stub pipeline even when API key is set
# TRACE_EVALUATE_MODE=stub

# Guardrails
TRACE_MAX_CLAIMS=10
TRACE_EVALUATE_TIMEOUT_MS=45000

# Optional: public app URL for deploy previews / SDK clients
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Phase 9 — batch evaluate & embed API (no extra keys required)
# POST /api/evaluate       — single assistant message
# POST /api/evaluate/batch — document → claim report
# GET  /api/v1/trace       — API manifest
# SDK: src/sdk/trace-client.ts (TraceClient)
